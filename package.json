{
  "name": "rhygym",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node --max-old-space-size=2048 node_modules/vite/bin/vite.js",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit",
    "gen:etudes": "tsx scripts/generate-etudes.ts"
  },
  "dependencies": {
    "@tonejs/midi": "^2.0.28",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vexflow": "^5.0.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "jsdom": "^25.0.1",
    "tsx": "^4.22.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
